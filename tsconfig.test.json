{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "types": ["node"],
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/renderer/src/*.ts", "src/renderer/src/*.tsx"],
      "@shared/*": ["src/shared/*.ts"]
    },
    "skipLibCheck": true,
    "rootDir": ".",
    "outDir": ".tmp-test"
  },
  "include": [
    "tests/**/*.test.ts",
    "src/renderer/src/state/agentMemory.ts",
    "src/renderer/src/state/conversationRouting.ts"
  ]
}
