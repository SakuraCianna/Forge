{
  "name": "forge",
  "version": "0.1.1",
  "description": "Open-source local AI coding agent desktop app",
  "author": "SakuraCianna",
  "license": "MIT",
  "private": true,
  "type": "module",
  "main": "out/main/index.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/SakuraCianna/Forge.git"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "npm run typecheck && electron-vite build",
    "release:check": "npm run lint && npm run build",
    "dist:win": "npm run build && electron-builder --win --x64 --publish never",
    "typecheck": "tsc -p tsconfig.node.json --noEmit && tsc -p tsconfig.web.json --noEmit",
    "lint": "eslint ."
  },
  "dependencies": {
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@tailwindcss/vite": "^4.3.0",
    "lucide-react": "^1.16.0",
    "mammoth": "^1.12.0",
    "pdfjs-dist": "^6.0.227",
    "prettier": "^3.8.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "read-excel-file": "^9.0.10",
    "shiki": "^4.1.0",
    "tailwindcss": "^4.3.0",
    "tesseract.js": "^7.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "^42.3.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "eslint": "^10.4.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0",
    "vite": "^7.3.3"
  },
  "build": {
    "appId": "com.sakuracianna.forge",
    "productName": "Forge",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "asar": true,
    "files": [
      "out/**/*",
      "package.json"
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "nsis"
      ],
      "signAndEditExecutable": false,
      "artifactName": "${productName}-${version}-${arch}-setup.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false
    }
  }
}
